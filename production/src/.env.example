# Vercel AI Gateway API key — required for the Claude vision call when running locally.
# Get one at https://vercel.com/dashboard → AI Gateway → API Keys.
# On a Vercel deployment this is provided automatically via OIDC (no key needed).
AI_GATEWAY_API_KEY=

# Optional: override the vision model (defaults to anthropic/claude-haiku-4.5,
# which runs on the AI Gateway free tier). For tougher real-world photos or
# stricter bold-detection, point this at a paid Sonnet/Opus tier.
# VISION_MODEL=anthropic/claude-sonnet-4.6
